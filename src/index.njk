---
layout: base.njk
title: "גל דִּיסֵנִי | אמנות מקורית, פורטרטים וסדנאות"
description: "הגלריה של גל דִּיסֵנִי, יצירות מקוריות, פורטרטים אישיים וסדנאות אמנות בחדרה."
activeNav: "גלריה"
permalink: "/index.html"
scripts:
  - /js/mark-list.js
---
{% set p = pages.home %}
{% set printFrom = pages.pricing.materials | priceRange([]) %}
{% set commissionFrom = pages.commissions.works | minPrice("price") %}
{% set workshopFrom = workshops | minPrice("priceFromILS") %}
<section class="artist-opening">
  <a class="artist-opening-logo" href="/">
    <img class="artist-logo" src="/images/brand-label-white.webp" alt="{{ site.brand }}">
    <p class="artist-signature-line">יצירות מקוריות מאת {{ site.brand }}</p>
  </a>
  <figure class="artist-opening-art">
    <img src="{{ p.heroImage }}" alt="{{ p.heroImageAlt }}">
  </figure>
  <div class="artist-opening-copy">
    <h1 id="hero-title">{{ p.headingLine1 }}<br><span>{{ p.headingLine2 }}</span></h1>
    <p class="artist-opening-lead">{{ p.leadText }}</p>
    <div class="opening-assurance">
      <p>{{ p.assuranceLine1 }}</p>
      <p>{{ p.assuranceLine2 }}</p>
    </div>
  </div>
</section>

<section class="home-gates" aria-label="דרכים ליצור ולרכוש">
  <a class="home-gate-card" href="/collections/originals/">
    <span class="home-gate-image"><img src="{{ artworks[0].thumb }}" alt="" loading="lazy"></span>
    <span class="home-gate-copy">
      <strong>יצירות מקוריות</strong>
      <small>עבודות חד-פעמיות, זמינות לרכישה</small>
    </span>
  </a>
  <a class="home-gate-card" href="/collections/prints/">
    <span class="home-gate-image"><img src="{{ artworks[1].thumb }}" alt="" loading="lazy"></span>
    <span class="home-gate-copy">
      <strong>הדפסים אמנותיים</strong>
      <small>החל מ-{{ printFrom.low | numberFormat }} ₪</small>
    </span>
  </a>
  <a class="home-gate-card" href="/commissions/">
    <span class="home-gate-image"><img src="{{ pages.commissions.heroImage }}" alt="" loading="lazy"></span>
    <span class="home-gate-copy">
      <strong>יצירות בהזמנה</strong>
      <small>החל מ-{{ commissionFrom | numberFormat }} ₪</small>
    </span>
  </a>
  <a class="home-gate-card" href="/workshops/">
    <span class="home-gate-image"><img src="{{ workshops[0].cardImage }}" alt="" loading="lazy"></span>
    <span class="home-gate-copy">
      <strong>סדנאות</strong>
      <small>החל מ-{{ workshopFrom | numberFormat }} ₪</small>
    </span>
  </a>
</section>

<section class="gallery section home-gallery">
  <div class="gallery-editorial home-art-grid">
    {% for artwork in artworks %}
    <figure class="gallery-item">
      <a class="gallery-link" href="/products/{{ artwork.slug }}/">
        <span class="gallery-frame"><img src="{{ artwork.thumb }}" alt="{{ artwork.name }}" loading="lazy"></span>
        <figcaption><strong title="{{ artwork.name }}">{{ artwork.name }}</strong></figcaption>
      </a>
    </figure>
    {% endfor %}
  </div>
</section>
