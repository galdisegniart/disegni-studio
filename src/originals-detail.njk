---
pagination:
  data: artworks
  size: 1
  alias: artwork
permalink: "/originals/{{ artwork.slug }}/index.html"
layout: base-bare.njk
scripts:
  - /js/sold-out.js
  - /js/share.js
eleventyComputed:
  title: "{{ artwork.name }} — יצירה מקורית | גל דִּיסֵנִי"
  description: "{{ artwork.name }}, {{ artwork.description }}"
---
{% set pay = pages.payment %}

<section class="artwork-detail">
  <div class="artwork-utility">
    <a class="artwork-back" href="/collections/originals/"><span aria-hidden="true">→</span> חזרה למקוריות זמינות</a>
  </div>
  <div class="artwork-detail-grid">
    <figure class="artwork-stage">
      <img src="{{ artwork.image }}" alt="{{ artwork.alt }}">
      {% if not artwork.originalAvailable %}
      <span class="sold-out-badge">נמכר</span>
      {% endif %}
    </figure>
    <div class="artwork-detail-copy">
      <p class="artwork-detail-medium">{{ artwork.detailMedium }}</p>
      <h1>{{ artwork.name }}</h1>
      <p class="artwork-detail-description">{{ artwork.description }}</p>

      {% if artwork.originalAvailable %}
      <p class="original-price">{{ artwork.originalPrice }} ₪</p>
      {% else %}
      <p class="original-price original-price-sold-out">נמכר</p>
      {% endif %}

      <div class="original-purchase-block">
        {% if artwork.originalAvailable %}
        <a class="cta" href="#purchase">{{ purchaseButtons.originalLabel }} <span aria-hidden="true">←</span></a>
        {% else %}
        <button type="button" class="cta js-original-sold-out">{{ purchaseButtons.originalLabel }}</button>
        {% endif %}
        <button class="artwork-share js-share" type="button" data-share-title="{{ artwork.name }} | {{ site.brand }}" data-share-text="{{ artwork.name }}, {{ artwork.description }}"><span aria-hidden="true">↗</span> <span class="js-share-label">שיתוף</span></button>
      </div>

      <a class="original-crosslink" href="/products/{{ artwork.slug }}/">רוצים בכל זאת הדפס אמנותי של היצירה? <span aria-hidden="true">←</span></a>
    </div>
  </div>

  {% if artwork.originalAvailable %}
  <div class="artwork-purchase" id="purchase">
    <div class="section-label"><span>{{ pay.sectionLabel }}</span></div>
    <h2>{{ pay.heading }}</h2>
    <p class="artwork-purchase-lead">{{ pay.lead }}</p>
    <p class="artwork-purchase-original-note">לרכישת היצירה המקורית "{{ artwork.name }}" במחיר {{ artwork.originalPrice }} ₪, בצעו העברה בנקאית לפרטים שלהלן ואשרו ב-WhatsApp.</p>
    <dl class="artwork-purchase-bank">
      <div><dt>בנק</dt><dd>{{ pay.bankName }} ({{ pay.bankCode }})</dd></div>
      <div><dt>סניף</dt><dd>{{ pay.branch }}</dd></div>
      <div><dt>מספר חשבון</dt><dd dir="ltr">{{ pay.accountNumber }}</dd></div>
      <div><dt>שם בעל החשבון</dt><dd>{{ pay.accountHolder }}</dd></div>
    </dl>
    <a class="cta js-whatsapp" href="{{ ('שלום גל, ביצעתי העברה בנקאית עבור היצירה המקורית \"' ~ artwork.name ~ '\". אשמח לתיאום המשלוח.') | waLink }}" target="_blank" rel="noopener noreferrer">אישור העברה ב-WhatsApp <span>←</span></a>
    <p class="artwork-purchase-note">{{ pay.waNote }}</p>
  </div>
  {% endif %}
</section>

<div class="sold-out-modal" id="sold-out-modal" hidden>
  <div class="sold-out-modal-box" role="alertdialog" aria-labelledby="sold-out-modal-title">
    <p class="sold-out-modal-title" id="sold-out-modal-title">לא ניתן לבצע רכישה</p>
    <p class="sold-out-modal-text">מצטערים, היצירה המקורית אינה במלאי.</p>
    <button type="button" class="cta js-sold-out-close">אישור</button>
  </div>
</div>
