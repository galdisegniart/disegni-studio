---
layout: base.njk
activeNav: "הדפסים"
permalink: "/collections/prints/index.html"
scripts:
  - /js/catalog-filter.js
  - /js/mark-list.js
eleventyComputed:
  title: "{{ pages.prints.title }}"
  description: "{{ pages.prints.metaDescription }}"
---
{% set p = pages.prints %}
<!-- force redeploy -->
<section class="gallery-intro-minimal">
  <div class="shop-intro-layout">
    <h1>{{ p.heading }}</h1>
    <div class="shop-intro-copy">
      <p>{{ p.heroText }}</p>
      <a class="cta cta-outline shop-originals-link" href="/">{{ p.originalsLinkLabel }} <span aria-hidden="true">←</span></a>
    </div>
  </div>
</section>

<section class="artwork-catalog gallery-catalog-compact section">
  <div class="catalog-toolbar">
    <h2>{{ p.catalogHeading }}</h2>
    <div class="catalog-filters">
      <button class="catalog-filter active" type="button" data-filter="all" aria-pressed="true">{{ p.filterAllLabel }}</button>
      <button class="catalog-filter" type="button" data-filter="drawing" aria-pressed="false">{{ p.filterDrawingLabel }}</button>
      <button class="catalog-filter" type="button" data-filter="mixed" aria-pressed="false">{{ p.filterMixedLabel }}</button>
    </div>
  </div>
  <div class="artwork-grid">
    {% for artwork in artworks %}
    <article class="artwork-card" id="{{ artwork.slug }}" data-category="{{ artwork.category }}">
      <a class="artwork-tile" href="/products/{{ artwork.slug }}/" aria-label="כניסה ליצירה {{ artwork.name }}">
        <span class="artwork-tile-image"><img src="{{ artwork.thumb }}" alt="{{ artwork.alt }}" loading="lazy"></span>
        <span class="artwork-tile-caption"><strong lang="en">{{ artwork.name }}</strong><small>{{ artwork.galleryMedium }}</small></span>
      </a>
    </article>
    {% endfor %}
  </div>
</section>
