---
pagination:
  data: artworks
  size: 1
  alias: artwork
permalink: "/products/{{ artwork.slug }}/index.html"
layout: base-bare.njk
scripts:
  - /js/cart.js
  - /js/back-link.js
  - /js/share.js
  - /js/product-gallery.js
  - /js/artwork-zoom.js
eleventyComputed:
  title: "{{ artwork.name }} | גל דִּיסֵנִי"
  description: "{{ artwork.name }}, {{ artwork.description }}"
  ogImage: "{{ artwork.image }}"
---
{% set seq = artworks | artworkSequence(artwork) %}
{% set pricing = pages.pricing %}
{% set extraMaterials = artwork.extraMaterials or [] %}

{% set range = pricing.materials | priceRange(extraMaterials) %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ (artwork.name ~ " - הדפס אמנותי") | dump | safe }},
  "image": "{{ site.siteUrl }}{{ artwork.image }}",
  "description": {{ (artwork.name ~ ", " ~ artwork.description) | dump | safe }},
  "url": "{{ site.siteUrl }}{{ page.url }}",
  "brand": { "@id": "{{ site.siteUrl }}/#person" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "ILS",
    "lowPrice": "{{ range.low }}",
    "highPrice": "{{ range.high }}",
    "availability": "https://schema.org/InStock",
    "url": "{{ site.siteUrl }}{{ page.url }}"
  }
}
</script>

<section class="artwork-detail">
  {% set crumbs = [
    { label: "בית", href: "/" },
    { label: "הדפסים", href: "/collections/prints/" },
    { label: artwork.name }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
  <div class="artwork-utility">
    <a class="artwork-back js-back-link" href="/"><span aria-hidden="true">→</span> <span class="js-back-label">חזרה לגלריה</span></a>
  </div>
  <div class="artwork-detail-grid">
  {% if artwork.gallery and artwork.gallery.length %}
  <div class="artwork-gallery">
    <figure class="artwork-stage">
      <img class="js-product-gallery-main" src="{{ artwork.image }}" alt="{{ artwork.alt }}">
    </figure>
    <div class="artwork-thumbnails" aria-label="תמונות נוספות של {{ artwork.name }}">
      <button class="artwork-thumbnail is-active js-product-gallery-thumb" type="button" data-image="{{ artwork.image }}" data-alt="{{ artwork.alt }}" aria-label="הצגת התמונה הראשית" aria-current="true">
        <img src="{{ artwork.thumb or artwork.image }}" alt="" loading="lazy">
      </button>
      {% for galleryImage in artwork.gallery %}
      <button class="artwork-thumbnail js-product-gallery-thumb" type="button" data-image="{{ galleryImage.image }}" data-alt="{{ galleryImage.alt or artwork.alt }}" aria-label="הצגת תמונה נוספת {{ loop.index }}">
        <img src="{{ galleryImage.thumb or galleryImage.image }}" alt="" loading="lazy">
      </button>
      {% endfor %}
    </div>
  </div>
  {% else %}
  <figure class="artwork-stage">
    <img src="{{ artwork.image }}" alt="{{ artwork.alt }}">
  </figure>
  {% endif %}
  <div class="artwork-detail-copy">
    <p class="artwork-detail-medium">{{ artwork.detailMedium }}</p>
    <h1>{{ artwork.name }}</h1>
    <p class="artwork-detail-description">{{ artwork.description }}</p>
    <div class="print-order" data-artwork-slug="{{ artwork.slug }}" data-artwork-name="{{ artwork.name }}">
      <p class="print-order-kicker">{{ purchaseButtons.printLabel }}</p>

      <div class="print-order-quality">
        <p class="print-order-quality-label">איכות גבוהה</p>
        <h2 class="print-order-quality-heading">אפשרויות הדפסה</h2>
        <ul class="print-order-quality-list">
          {% for material in pricing.materials %}
          {% if material.id == "paper" or material.id in extraMaterials %}
          <li><span class="print-order-quality-icon" aria-hidden="true">◈</span><span><strong>{{ material.name }}</strong> — {{ material.description }}</span></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="print-order-head">
        <div class="currency-toggle-mini">
          <button type="button" class="js-currency-toggle active" data-currency="ILS">₪ · ס"מ</button>
          <span>·</span>
          <button type="button" class="js-currency-toggle" data-currency="USD">$ · inch</button>
        </div>
      </div>

      <p class="print-order-price">סה"כ <span class="js-live-price">—</span></p>

      <select class="js-size-data" hidden aria-hidden="true" tabindex="-1">
        {% for material in pricing.materials %}
        {% if material.id == "paper" or material.id in extraMaterials %}
        {% for size in material.sizes %}
        <option value="{{ material.id }}:{{ size.id }}" data-material="{{ material.id }}" data-material-name="{{ material.name }}" data-note="{{ material.note }}" data-size-id="{{ size.id }}" data-label-in="{{ size.labelIn }}" data-label-cm="{{ size.labelCm }}" data-price-ils="{{ size.priceILS }}" data-price-usd="{{ size.priceUSD }}"{% if not size.available %} disabled{% endif %}></option>
        {% endfor %}
        {% endif %}
        {% endfor %}
      </select>

      <div class="print-order-selects">
        <div class="print-order-field">
          <span class="print-order-field-label">סגנון</span>
          <select class="js-style-select" aria-label="בחירת סגנון הדפסה">
            <option value="" selected>בחרו סגנון</option>
            {% for material in pricing.materials %}
            {% if material.id == "paper" or material.id in extraMaterials %}
            <option value="{{ material.id }}">{{ material.name }}</option>
            {% endif %}
            {% endfor %}
          </select>
        </div>
        <div class="print-order-field">
          <span class="print-order-field-label">מידה</span>
          <select class="js-size-select" aria-label="בחירת גודל" disabled>
            <option value="" selected>בחרו סגנון קודם</option>
          </select>
        </div>
        <div class="print-order-field">
          <span class="print-order-field-label">מסגרת</span>
          <select class="js-frame-select" aria-label="בחירת מסגרת">
            <option value="none" selected>ללא מסגרת</option>
          </select>
        </div>
      </div>

      <div class="print-order-field print-order-qty-field">
        <span class="print-order-field-label">כמות</span>
        <div class="qty-stepper">
          <button type="button" class="js-order-qty-minus" aria-label="הפחתת כמות">−</button>
          <span class="js-order-qty">1</span>
          <button type="button" class="js-order-qty-plus" aria-label="הוספת כמות">+</button>
        </div>
      </div>

      <button type="button" class="cta js-add-to-cart">הוספה לעגלה</button>
      <a class="cta cta-outline js-whatsapp" href="{{ ('שלום גל, יש לי שאלה לפני רכישת הדפס של \"' ~ artwork.name ~ '\".') | waLink }}" target="_blank" rel="noopener noreferrer">שאלות לפני רכישה ב-WhatsApp</a>

      <p class="print-order-note js-print-order-note"></p>
      <button class="artwork-share js-share" type="button" data-share-title="{{ artwork.name }} | {{ site.brand }}" data-share-text="{{ artwork.name }}, {{ artwork.description }}"><span aria-hidden="true">↗</span> <span class="js-share-label">שיתוף</span></button>

      <details class="print-order-details">
        <summary><span aria-hidden="true">☰</span> פרטים</summary>
        <div class="print-order-details-body">
          <p>היצירה המקורית נוצרה ב{{ artwork.detailMedium }}. ההדפס הוא רפרודוקציה איכותית שלה, מיוצר לפי הזמנה.</p>
          <p>{{ pricing.materials[0].note }}</p>
        </div>
      </details>

      <details class="print-order-details">
        <summary><span aria-hidden="true">✦</span> השראה</summary>
        <div class="print-order-details-body">
          <p>{{ artwork.description }}</p>
        </div>
      </details>

      <details class="print-order-details">
        <summary><span aria-hidden="true">⬡</span> קולקציה</summary>
        <div class="print-order-details-body">
          <p>היצירה שייכת לעולם ה{{ artwork.galleryMedium }} של {{ site.brand }}.</p>
        </div>
      </details>

      <details class="print-order-details">
        <summary><span aria-hidden="true">©</span> זכויות יוצרים</summary>
        <div class="print-order-details-body">
          <p>כל היצירות, הדימויים והתוכן באתר זה מוגנים בזכויות יוצרים של {{ site.brand }}. <a href="/rights/">למדיניות זכויות היוצרים המלאה</a></p>
        </div>
      </details>
    </div>
    <a class="original-crosslink" href="/originals/{{ artwork.slug }}/">מתעניינים ביצירה המקורית של "{{ artwork.name }}"? <span aria-hidden="true">←</span></a>
  </div>
  </div>
</section>

<section class="artwork-more">
  <div class="artwork-more-head">
    <a class="js-back-link" href="/"><span aria-hidden="true">→</span> <span class="js-back-label">חזרה לגלריה</span></a>
    <div class="artwork-sequence">
      <a id="previous-artwork" href="/products/{{ seq.prev.slug }}/" aria-label="היצירה הקודמת, {{ seq.prev.name }}">הקודמת</a>
      <span>/</span>
      <a id="next-artwork" href="/products/{{ seq.next.slug }}/" aria-label="היצירה הבאה, {{ seq.next.name }}">הבאה</a>
    </div>
  </div>
  <div class="artwork-more-grid">
    {% for item in seq.more %}
    <a class="more-artwork-card" href="/products/{{ item.slug }}/">
      <span class="more-artwork-image"><img src="{{ item.thumb }}" alt="{{ item.name }}" loading="lazy"></span>
      <span class="more-artwork-caption"><strong lang="en">{{ item.name }}</strong><small>{{ item.galleryMedium }}</small><i aria-hidden="true">←</i></span>
    </a>
    {% endfor %}
  </div>
</section>
