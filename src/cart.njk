---
layout: base.njk
title: "עגלת קניות | גל דִּיסֵנִי"
description: "עגלת הקניות שלכם באתר גל דִּיסֵנִי."
permalink: "/cart/index.html"
---
{% set pay = pages.payment %}
{% set pricing = pages.pricing %}
<section class="cart-page section" id="cart-root" data-shipping-flat="{{ pricing.shippingIL.flatILS }}" data-shipping-threshold="{{ pricing.shippingIL.freeThresholdILS }}">
  <div class="section-label"><span>עגלת קניות</span></div>
  <h1>סיכום ההזמנה שלכם</h1>

  <div class="currency-toggle cart-currency-toggle">
    <button type="button" class="js-currency-toggle active" data-currency="ILS">₪ · ס"מ</button>
    <button type="button" class="js-currency-toggle" data-currency="USD">$ · inch</button>
  </div>

  <p id="cart-empty">העגלה שלכם ריקה. <a href="/">חזרה לגלריה</a> לבחירת יצירה.</p>

  <ul id="cart-items" class="cart-items"></ul>

  <form id="cart-customer-form" class="cart-customer" hidden>
    <h2 class="cart-customer-heading">פרטי משלוח ויצירת קשר</h2>
    <div class="cart-customer-field">
      <label for="customer-name">שם מלא *</label>
      <input type="text" id="customer-name" required autocomplete="name">
    </div>
    <div class="cart-customer-field">
      <label for="customer-phone">טלפון *</label>
      <input type="tel" id="customer-phone" required autocomplete="tel">
    </div>
    <div class="cart-customer-field">
      <label for="customer-email">דוא"ל (לא חובה)</label>
      <input type="email" id="customer-email" autocomplete="email">
    </div>
    <div class="cart-customer-field">
      <label for="customer-address">כתובת למשלוח *</label>
      <textarea id="customer-address" required autocomplete="street-address" rows="2"></textarea>
    </div>
  </form>

  <div id="cart-summary" class="cart-summary" hidden>
    <div class="cart-summary-row"><span>סכום ביניים</span><span id="cart-subtotal"></span></div>
    <div class="cart-summary-row"><span>משלוח</span><span id="cart-shipping"></span></div>
    <div class="cart-summary-row cart-summary-total"><span>סה"כ</span><span id="cart-total"></span></div>
    <a id="cart-whatsapp" class="cta" href="#" target="_blank" rel="noopener noreferrer">המשך להזמנה ב-WhatsApp <span>←</span></a>
    <p class="cart-summary-note">{{ pay.lead }}</p>
    <dl class="artwork-purchase-bank">
      <div><dt>בנק</dt><dd>{{ pay.bankName }} ({{ pay.bankCode }})</dd></div>
      <div><dt>סניף</dt><dd>{{ pay.branch }}</dd></div>
      <div><dt>מספר חשבון</dt><dd dir="ltr">{{ pay.accountNumber }}</dd></div>
      <div><dt>שם בעל החשבון</dt><dd>{{ pay.accountHolder }}</dd></div>
    </dl>
  </div>
</section>
