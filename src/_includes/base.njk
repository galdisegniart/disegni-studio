<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css?v={{ buildTime }}">
</head>
<body id="top" data-whatsapp="{{ site.whatsappNumber }}">

<header class="header site-header">
  <a class="brand" href="/" aria-label="{{ site.brand }}, דף הבית">{{ site.brand }}</a>
  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="פתיחת תפריט ניווט">
    <span></span><span></span><span></span>
  </button>
  <nav class="main-nav" id="main-nav" aria-label="ניווט ראשי">
    {% for item in site.nav %}
    <a{% if item.label == activeNav %} class="active"{% endif %} href="{{ item.href }}">{{ item.label }}</a>
    {% endfor %}
  </nav>
  <a class="header-cart" href="/cart/" aria-label="עגלת קניות">
    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="9" cy="21" r="1.4"></circle><circle cx="18" cy="21" r="1.4"></circle><path d="M2.5 3h2l2.2 12.2a2 2 0 0 0 2 1.65h8.15a2 2 0 0 0 1.97-1.65L21 8H6"></path></svg>
    <span class="js-cart-count" hidden>0</span>
  </a>
</header>

<nav class="quick-links-rail" aria-label="קישורים מהירים">
  <a href="{{ site.contactHref }}" aria-label="יצירת קשר">
    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m4 6.5 8 6 8-6"></path></svg>
  </a>
  <a href="{{ site.socials[1].href }}" target="_blank" rel="noopener noreferrer" aria-label="טיקטוק של {{ site.brand }}">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.2 3v11.1a4.7 4.7 0 1 1-4.1-4.65v3.05a1.8 1.8 0 1 0 1.2 1.7V3h2.9Zm0 0c.35 2.05 1.55 3.45 3.8 3.8v3.1c-1.55-.05-2.85-.5-3.8-1.25"></path></svg>
  </a>
  <a href="{{ site.socials[0].href }}" target="_blank" rel="noopener noreferrer" aria-label="אינסטגרם של {{ site.brand }}">
    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4.2"></circle><circle cx="17.4" cy="6.7" r="1"></circle></svg>
  </a>
</nav>

{{ content | safe }}

{% include "partials/footer.njk" %}

{% for s in scripts %}
<script src="{{ s }}?v={{ buildTime }}"></script>
{% endfor %}
<script src="/js/cart.js?v={{ buildTime }}"></script>
<script src="/js/nav-toggle.js?v={{ buildTime }}"></script>
</body>
</html>
