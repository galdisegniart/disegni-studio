<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="{{ site.siteUrl }}{{ page.url }}">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<meta property="og:type" content="website">
<meta property="og:locale" content="he_IL">
<meta property="og:site_name" content="{{ site.brand }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}">
<meta property="og:image" content="{{ site.siteUrl }}{{ ogImage or '/images/disegni-profile.webp' }}">
<meta name="twitter:card" content="summary_large_image">
{% include "partials/schema-org.njk" %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css?v={{ buildTime }}">
</head>
<body id="top" data-whatsapp="{{ site.whatsappNumber }}">

{{ content | safe }}

{% for s in scripts %}
<script src="{{ s }}?v={{ buildTime }}"></script>
{% endfor %}
</body>
</html>
