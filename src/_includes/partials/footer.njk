<footer>
  <div class="footer-meta">
    <span>{{ site.tagline }}</span>
  </div>
  <div class="footer-brand">
    <span>{{ site.brand }}</span>
    <a href="#top">חזרה למעלה ↑</a>
  </div>
  <nav class="site-socials" aria-label="{{ site.brand }} ברשתות החברתיות">
    <a href="{{ site.socials[0].href }}" target="_blank" rel="noopener noreferrer" aria-label="אינסטגרם של {{ site.brand }}">
      <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4.2"></circle><circle cx="17.4" cy="6.7" r="1"></circle></svg>
    </a>
    <a href="{{ site.socials[1].href }}" target="_blank" rel="noopener noreferrer" aria-label="טיקטוק של {{ site.brand }}">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.2 3v11.1a4.7 4.7 0 1 1-4.1-4.65v3.05a1.8 1.8 0 1 0 1.2 1.7V3h2.9Zm0 0c.35 2.05 1.55 3.45 3.8 3.8v3.1c-1.55-.05-2.85-.5-3.8-1.25"></path></svg>
    </a>
    <a href="{{ site.socials[2].href }}" target="_blank" rel="noopener noreferrer" aria-label="פייסבוק של {{ site.brand }}">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 21v-8h2.8l.45-3H14V8.2c0-.9.3-1.5 1.65-1.5h1.75V4.05c-.3-.05-1.35-.15-2.55-.15-2.5 0-4.2 1.5-4.2 4.35V10H8v3h2.65v8H14Z"></path></svg>
    </a>
  </nav>
  <p class="footer-legal">© {{ currentYear }} {{ site.brand }}. כל הזכויות שמורות. <a href="/rights/">מדיניות זכויות יוצרים</a> · <a href="/returns/">מדיניות ביטולים והחזרים</a>{% if site.businessNumber %} · עוסק מורשה {{ site.businessNumber }}{% endif %}</p>
</footer>
